{
  "name": "anima-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @anima/web dev",
    "dev:full": "pnpm --parallel --filter @anima/web --filter @anima/api run dev",
    "demo": "pnpm --filter @anima/demo start",
    "build": "pnpm -r run typecheck && pnpm --filter @anima/web build",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @anima/web test:e2e",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r run typecheck",
    "mission": "pnpm --filter @anima/missions-runner start"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
